# twitterapi.io API key (third-party Twitter data provider - NOT the
# official api.twitter.com API). Get it from https://twitterapi.io/dashboard.
# Auth is a simple X-API-Key header, billed per call (~$0.15/1k tweets).
# The service falls back to CoinGecko-derived social signals automatically
# if this is missing or rejected.
TWITTERAPI_IO_KEY=

# Old var name, still read as a fallback if TWITTERAPI_IO_KEY isn't set -
# no need to keep both, this just avoids breaking an existing deploy.
TWITTER_BEARER_TOKEN=

# x402 payment gate (app/x402.py), via OKX's okxweb3-app-x402 seller SDK.
#
# OKX_API_KEY / OKX_SECRET_KEY / OKX_PASSPHRASE come from the OKX Developer
# Portal (https://web3.okx.com/onchain-os/dev-portal) - separate from your
# Agentic Wallet login.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Your EVM wallet address (the payment recipient). Get it by running
# `onchainos wallet status` (or `wallet addresses`) in an agent session
# that's logged into your Agentic Wallet.
X402_RECEIVING_ADDRESS=

# Human-readable USD price per call, e.g. "0.5" = $0.50.
X402_PRICE_USDC=0.5

# Set true only once OKX_API_KEY/SECRET_KEY/PASSPHRASE and
# X402_RECEIVING_ADDRESS are all filled in AND you've tested a real payment
# end-to-end. Keeping this false makes /sentiment free and lets you
# demo/test the scoring logic without a live payment rail.
X402_ENABLED=false
