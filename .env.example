# Twitter/X API v2 bearer token (recent search endpoint). Free tier likely cannot
# call search/recent - the service will fall back to CoinGecko-derived signals
# automatically if this 401s/403s/429s.
TWITTER_BEARER_TOKEN=

# x402 / OKX Payment SDK settings - fill in once you've completed the
# "Log in to the Agentic Wallet" + "Register as an ASP" steps from
# https://www.okx.ai/tutorial/asp
X402_RECEIVING_ADDRESS=
X402_PRICE_USDC=0.5
X402_NETWORK=x-layer
X402_ENABLED=false

# Set true once you've validated the payment flow end-to-end. Keeping this
# false lets you demo/test the scoring logic without a live payment rail.
